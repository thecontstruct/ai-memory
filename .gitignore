*.egg-info/

# Oversight directory (private - stored in parent dev-ai-memory/oversight/)
/oversight/

# POV oversight agent (user-specific, not for repo)
/pov/

# Claude Code local settings (user-specific)
.claude/settings.json
# Local settings contain secrets (e.g. QDRANT_API_KEY) — never commit (fixes #38)
.claude/settings.local.json

# Secrets — NEVER commit plaintext secrets
# docker/.env is explicitly listed above (BUG-181)

# SOPS encrypted file IS safe to commit (values encrypted)
# By default, secrets.enc.yaml is NOT ignored and WILL be committed.
# The commented line below is for reference only — uncomment if you want to
# explicitly whitelist it (useful if you have a broader ignore pattern):
# !docker/secrets.enc.yaml

# age private key — NEVER commit (default SOPS/age key location)
**/.config/sops/age/keys.txt

# Backup/verification directories (user-local, not for repo)
_ai-memory/_ai-memory.restructred/
_ai-memory/pov.v1.bak/

# AI Memory audit trail (ephemeral/sensitive data)
.audit/
