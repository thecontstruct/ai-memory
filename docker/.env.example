# =============================================================================
# AI MEMORY MODULE — Environment Configuration
# =============================================================================
#
# This is the ONLY .env file. Docker Compose reads it from docker/.env
#
# SETUP:
#   1. Copy: cp .env.example .env
#   2. Fill in Section 1 (Your API Keys) — only the integrations you use
#   3. Run the installer: ./scripts/install.sh /path/to/your/project
#      The installer auto-generates all Section 2 credentials and starts Docker.
#
# After install, manage the stack with: scripts/stack.sh start|stop|restart|status
#
# Everything left blank in Section 2 is auto-generated by the installer.
# Everything in Sections 3-5 has working defaults — change only if needed.
#
# IMPORTANT: Do NOT put inline comments on KEY=value lines.
# Docker Compose and pydantic-settings parse them as part of the value.
#
# =============================================================================


# =============================================================================
# SECTION 1: YOUR API KEYS
# =============================================================================
# These are the ONLY values you need to provide manually.
# Leave blank any integrations you don't use.
# =============================================================================

# --- LLM Providers (at least one needed for memory classification) ---
# Ollama Cloud: https://ollama.com/settings/keys (optional)
OLLAMA_API_KEY=
# OpenRouter: https://openrouter.ai/keys (recommended, free tier available)
OPENROUTER_API_KEY=
# Anthropic: https://console.anthropic.com/ (optional)
ANTHROPIC_API_KEY=
# OpenAI: https://platform.openai.com/api-keys (optional)
OPENAI_API_KEY=

# --- GitHub Integration ---
# Fine-grained token: https://github.com/settings/tokens (repo scope)
GITHUB_TOKEN=
# Format: owner/repo (e.g., myorg/myproject)
GITHUB_REPO=

# --- Jira Integration ---
# Your Atlassian account email
JIRA_EMAIL=
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=
# Instance URL, e.g., https://yourteam.atlassian.net
JIRA_INSTANCE_URL=
# JSON array of project keys, e.g. ["PROJ"] or ["PROJ","TEAM"]
JIRA_PROJECTS=


# =============================================================================
# SECTION 2: AUTO-GENERATED — DO NOT EDIT
# =============================================================================
# The installer and langfuse_setup.sh auto-generate these on first install.
# To regenerate: delete the value and re-run the installer.
# =============================================================================

# --- Vector Database (installer generates) ---
QDRANT_API_KEY=
QDRANT_READ_ONLY_API_KEY=

# --- Monitoring (installer generates) ---
GRAFANA_ADMIN_PASSWORD=
GRAFANA_SECRET_KEY=
PROMETHEUS_ADMIN_PASSWORD=
# Derived from PROMETHEUS_ADMIN_PASSWORD
PROMETHEUS_BASIC_AUTH_HEADER=

# --- Langfuse Secrets (langfuse_setup.sh generates) ---
LANGFUSE_DB_PASSWORD=
LANGFUSE_CLICKHOUSE_PASSWORD=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_S3_ACCESS_KEY=
LANGFUSE_S3_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Langfuse Bootstrap (langfuse_setup.sh generates) ---
LANGFUSE_INIT_ORG_ID=
LANGFUSE_INIT_ORG_NAME=
LANGFUSE_INIT_PROJECT_ID=
LANGFUSE_INIT_PROJECT_NAME=
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_NAME=
LANGFUSE_INIT_USER_PASSWORD=

# --- Installer-Managed ---
# Set by installer (e.g., /home/user/.ai-memory)
AI_MEMORY_INSTALL_DIR=
# Set by installer (from git remote or folder name)
AI_MEMORY_PROJECT_ID=
# Container name prefix (for multi-stack isolation)
AI_MEMORY_CONTAINER_PREFIX=ai-memory


# =============================================================================
# SECTION 3: FEATURE TOGGLES
# =============================================================================
# All features enabled by default. Disable what you don't need.
# =============================================================================

# Auto-update ai-memory hooks on session start
AUTO_UPDATE_ENABLED=true
# Load ColBERT reranking model (~400MB download)
COLBERT_ENABLED=true
# ColBERT late-interaction reranking in search
COLBERT_RERANKING_ENABLED=true
# Time-based relevance decay for memories
DECAY_ENABLED=true
# Git-based freshness detection for code-patterns
FRESHNESS_ENABLED=true
# Store GitHub file contents as vectors
GITHUB_CODE_BLOB_ENABLED=true
# Sync GitHub issues/PRs/commits to memory (requires GITHUB_TOKEN)
GITHUB_SYNC_ENABLED=false
# Dense+sparse hybrid search with RRF fusion
HYBRID_SEARCH_ENABLED=true
# Progressive context injection (Tier 1 + Tier 2)
INJECTION_ENABLED=true
# Sync Jira issues/comments to memory (requires JIRA_API_TOKEN)
JIRA_SYNC_ENABLED=false
# LLM observability (adds ~16 GiB RAM, requires langfuse_setup.sh)
LANGFUSE_ENABLED=false
# LLM-based memory type classification
MEMORY_CLASSIFIER_ENABLED=true
# Parzival project oversight agent
PARZIVAL_ENABLED=true
# Security scanning for stored content
SECURITY_SCANNING_ENABLED=true
# Set to false to skip monitoring health checks (e.g. minimal stack without monitoring profile)
MONITORING_ENABLED=true


# =============================================================================
# SECTION 4: CONFIGURATION
# =============================================================================
# Grouped by subsystem. Defaults work out of the box.
# =============================================================================

# --- 4.1 LLM Providers & Models ---
# Auto-detects cloud if OLLAMA_API_KEY is set
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=sam860/LFM2:2.6b
OPENROUTER_MODEL=google/gemma-2-9b-it:free
ANTHROPIC_MODEL=claude-3-haiku-20240307
OPENAI_MODEL=gpt-4o-mini

# --- 4.2 Memory Classifier ---
# Primary provider: ollama | openrouter | claude | openai
MEMORY_CLASSIFIER_PRIMARY_PROVIDER=ollama
# Comma-separated fallback chain
MEMORY_CLASSIFIER_FALLBACK_PROVIDERS=openrouter
MEMORY_CLASSIFIER_CONFIDENCE_THRESHOLD=0.7
MEMORY_CLASSIFIER_RULE_CONFIDENCE=0.85
MEMORY_CLASSIFIER_MIN_CONTENT_LENGTH=20
MEMORY_CLASSIFIER_TIMEOUT=30
MEMORY_CLASSIFIER_MAX_TOKENS=500
MEMORY_CLASSIFIER_MAX_INPUT_CHARS=4000

# --- 4.3 Context Injection ---
# Tier 1 startup injection budget (tokens)
BOOTSTRAP_TOKEN_BUDGET=2500
# Tier 2 min score to inject
INJECTION_CONFIDENCE_THRESHOLD=0.6
INJECTION_BUDGET_FLOOR=500
INJECTION_BUDGET_CEILING=1500
# INJECTION_QUALITY_WEIGHT=0.5
# INJECTION_DENSITY_WEIGHT=0.3
# INJECTION_DRIFT_WEIGHT=0.2
# INJECTION_HARD_FLOOR=0.45
# INJECTION_THRESHOLD_CONVENTIONS=0.65
# INJECTION_THRESHOLD_CODE_PATTERNS=0.55
# INJECTION_THRESHOLD_DISCUSSIONS=0.60

# --- 4.4 Decay Scoring ---
# Blend: 0.7 semantic + 0.3 temporal
DECAY_SEMANTIC_WEIGHT=0.7
# Days until 50% decay per collection
DECAY_HALF_LIFE_CODE_PATTERNS=14
DECAY_HALF_LIFE_DISCUSSIONS=21
DECAY_HALF_LIFE_CONVENTIONS=60
DECAY_HALF_LIFE_JIRA_DATA=30
DECAY_HALF_LIFE_GITHUB=14
# DECAY_MIN_SCORE=0.1
# DECAY_TYPE_OVERRIDES=

# --- 4.5 Freshness Detection ---
# Commits since stored to classify as aging/stale/expired
FRESHNESS_COMMIT_THRESHOLD_AGING=3
FRESHNESS_COMMIT_THRESHOLD_STALE=10
FRESHNESS_COMMIT_THRESHOLD_EXPIRED=25
# FRESHNESS_PENALTY_FRESH=1.0
# FRESHNESS_PENALTY_AGING=0.9
# FRESHNESS_PENALTY_STALE=0.0
# FRESHNESS_PENALTY_EXPIRED=0.0
# FRESHNESS_PENALTY_UNVERIFIED=1.0
# FRESHNESS_PENALTY_UNKNOWN=0.8

# --- 4.6 Security Scanning ---
SECURITY_SCANNING_NER_ENABLED=true
SECURITY_BLOCK_ON_SECRETS=true
# Scan modes: relaxed | strict | off
SECURITY_SCAN_GITHUB_MODE=relaxed
SECURITY_SCAN_SESSION_MODE=relaxed

# --- 4.7 GitHub Sync ---
GITHUB_BRANCH=main
# Sync interval in seconds (1800 = 30 min)
GITHUB_SYNC_INTERVAL=1800
GITHUB_SYNC_ON_START=true
# Max file size for code blob storage (bytes)
GITHUB_CODE_BLOB_MAX_SIZE=102400
GITHUB_CODE_BLOB_EXCLUDE=node_modules,*.min.js,.git,__pycache__,*.pyc,build,dist,*.egg-info
# Comma-separated glob patterns to force-include (bypasses standard filter skips, not binary protection)
# Supported: *.ext (extension match) or bare-token (path segment match, e.g. Makefile)
# NOT supported: path patterns with / (e.g. src/*.py), bare * or *. (too broad)
# GITHUB_CODE_BLOB_INCLUDE=
# Optional hard ceiling for explicitly included files (defaults to 5x GITHUB_CODE_BLOB_MAX_SIZE)
# GITHUB_CODE_BLOB_INCLUDE_MAX_SIZE=
# Total timeout for code blob sync in service mode (seconds; default 30 min, max 7d for initial large-repo syncs)
# For large repos (100k+ files), set to 86400 (1 day) or 604800 (7 days) for initial sync
GITHUB_SYNC_TOTAL_TIMEOUT=1800
GITHUB_SYNC_INSTALL_TIMEOUT=600
GITHUB_SYNC_PER_FILE_TIMEOUT=60
GITHUB_SYNC_CIRCUIT_BREAKER_THRESHOLD=5
GITHUB_SYNC_CIRCUIT_BREAKER_RESET=60

# --- 4.8 Jira Sync ---
# Delay between Jira API calls in ms (rate limiting)
JIRA_SYNC_DELAY_MS=100

# --- 4.9 Parzival Agent ---
# Your name (used in greetings and handoffs)
PARZIVAL_USER_NAME=Developer
PARZIVAL_LANGUAGE=English
PARZIVAL_DOC_LANGUAGE=English
# Project-relative path to oversight directory
PARZIVAL_OVERSIGHT_FOLDER=oversight
PARZIVAL_HANDOFF_RETENTION=10

# --- 4.10 Langfuse Observability ---
# Langfuse web UI URL (for Python SDK)
LANGFUSE_BASE_URL=http://localhost:23100
# Trace retention in days
LANGFUSE_RETENTION_DAYS=90
# Trace flush worker interval in seconds
LANGFUSE_FLUSH_INTERVAL=5
LANGFUSE_TRACE_HOOKS=true
LANGFUSE_TRACE_SESSIONS=true

# --- 4.11 Embedding Models ---
MODEL_NAME_EN=jinaai/jina-embeddings-v2-base-en
MODEL_NAME_CODE=jinaai/jina-embeddings-v2-base-code
EMBEDDING_MODEL_DENSE_EN=jinaai/jina-embeddings-v2-base-en
EMBEDDING_MODEL_DENSE_CODE=jinaai/jina-embeddings-v2-base-code
# Container memory limit (two models ~ 3GB)
EMBEDDING_MEMORY_LIMIT=4G
EMBEDDING_MAX_RETRIES=2
EMBEDDING_BACKOFF_BASE=1.0
EMBEDDING_BACKOFF_CAP=15.0

# --- 4.12 Evaluator (LLM-as-Judge) ---
# Only needed if using provider=custom in evaluator_config.yaml
EVALUATOR_BASE_URL=
EVALUATOR_API_KEY=

# --- 4.13 Logging ---
# Python: DEBUG | INFO | WARNING | ERROR
AI_MEMORY_LOG_LEVEL=INFO
# Qdrant: TRACE | DEBUG | INFO | WARN | ERROR
QDRANT_LOG_LEVEL=INFO

# --- 4.14 Secrets Backend ---
# Options: sops-age | keyring | env-file
AI_MEMORY_SECRETS_BACKEND=env-file


# =============================================================================
# SECTION 5: INTERNAL / ADVANCED — DO NOT CHANGE
# =============================================================================
# Ports, hardcoded defaults. Only change if you have port conflicts.
# =============================================================================

# --- Service Ports ---
QDRANT_PORT=26350
QDRANT_GRPC_PORT=26351
EMBEDDING_PORT=28080
QDRANT_TIMEOUT=30
QDRANT_USE_HTTPS=false

# --- Langfuse Ports ---
LANGFUSE_WEB_PORT=23100
LANGFUSE_WORKER_PORT=23130
LANGFUSE_POSTGRES_PORT=25432
LANGFUSE_CLICKHOUSE_PORT=28123
LANGFUSE_REDIS_PORT=26379
LANGFUSE_MINIO_PORT=29000

# --- Classification Queue ---
AI_MEMORY_QUEUE_DIR=~/.ai-memory/queue

# --- Fixed Defaults ---
GRAFANA_ADMIN_USER=admin
