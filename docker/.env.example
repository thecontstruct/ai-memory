# =============================================================================
# AI MEMORY MODULE — Environment Configuration
# =============================================================================
#
# This is the ONLY .env file. Docker Compose reads it from docker/.env
#
# SETUP:
#   1. Copy: cp .env.example .env
#   2. Fill in Section 1 (Your API Keys) — only the integrations you use
#   3. Run the installer: ./scripts/install.sh /path/to/your/project
#      The installer auto-generates all Section 2 credentials and starts Docker.
#
# After install, manage the stack with: scripts/stack.sh start|stop|restart|status
#
# Everything left blank in Section 2 is auto-generated by the installer.
# Everything in Sections 3-5 has working defaults — change only if needed.
#
# =============================================================================


# =============================================================================
# SECTION 1: YOUR API KEYS
# =============================================================================
# These are the ONLY values you need to provide manually.
# Leave blank any integrations you don't use.
# =============================================================================

# --- LLM Providers (at least one needed for memory classification) ---
OLLAMA_API_KEY=                                 # https://ollama.com/settings/keys (cloud, optional)
OPENROUTER_API_KEY=                             # https://openrouter.ai/keys (recommended: free tier)
ANTHROPIC_API_KEY=                              # https://console.anthropic.com/ (optional)
OPENAI_API_KEY=                                 # https://platform.openai.com/api-keys (optional)

# --- GitHub Integration ---
GITHUB_TOKEN=                                   # https://github.com/settings/tokens (fine-grained, repo scope)
GITHUB_REPO=                                    # Format: owner/repo (e.g., myorg/myproject)

# --- Jira Integration ---
JIRA_EMAIL=                                     # Your Atlassian account email
JIRA_API_TOKEN=                                 # https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_INSTANCE_URL=                              # e.g., https://yourteam.atlassian.net
JIRA_PROJECTS=                                  # JSON array, e.g. ["PROJ"] or ["PROJ","TEAM"]


# =============================================================================
# SECTION 2: AUTO-GENERATED — DO NOT EDIT
# =============================================================================
# The installer and langfuse_setup.sh auto-generate these on first install.
# To regenerate: delete the value and re-run the installer.
# =============================================================================

# --- Vector Database ---
QDRANT_API_KEY=                                 # Installer generates
QDRANT_READ_ONLY_API_KEY=                       # Installer generates

# --- Monitoring ---
GRAFANA_ADMIN_PASSWORD=                         # Installer generates
GRAFANA_SECRET_KEY=                             # Installer generates
PROMETHEUS_ADMIN_PASSWORD=                      # Installer generates
PROMETHEUS_BASIC_AUTH_HEADER=                   # Derived from PROMETHEUS_ADMIN_PASSWORD

# --- Langfuse Secrets (langfuse_setup.sh generates) ---
LANGFUSE_DB_PASSWORD=
LANGFUSE_CLICKHOUSE_PASSWORD=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_S3_ACCESS_KEY=
LANGFUSE_S3_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Langfuse Bootstrap (langfuse_setup.sh generates) ---
LANGFUSE_INIT_ORG_ID=
LANGFUSE_INIT_ORG_NAME=
LANGFUSE_INIT_PROJECT_ID=
LANGFUSE_INIT_PROJECT_NAME=
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_NAME=
LANGFUSE_INIT_USER_PASSWORD=

# --- Installer-Managed ---
AI_MEMORY_INSTALL_DIR=                          # Set by installer
AI_MEMORY_PROJECT_ID=                           # Set by installer (from git remote or folder name)
AI_MEMORY_CONTAINER_PREFIX=ai-memory            # Set by installer


# =============================================================================
# SECTION 3: FEATURE TOGGLES
# =============================================================================
# All features enabled by default. Disable what you don't need.
# =============================================================================

AUTO_UPDATE_ENABLED=true                        # Auto-update ai-memory hooks on session start
COLBERT_ENABLED=true                            # Load ColBERT reranking model (~400MB download)
COLBERT_RERANKING_ENABLED=true                  # ColBERT late-interaction reranking in search
DECAY_ENABLED=true                              # Time-based relevance decay for memories
FRESHNESS_ENABLED=true                          # Git-based freshness detection for code-patterns
GITHUB_CODE_BLOB_ENABLED=true                   # Store GitHub file contents as vectors
GITHUB_SYNC_ENABLED=true                        # Sync GitHub issues/PRs/commits to memory
HYBRID_SEARCH_ENABLED=true                      # Dense+sparse hybrid search with RRF fusion
INJECTION_ENABLED=true                          # Progressive context injection (Tier 1 + Tier 2)
JIRA_SYNC_ENABLED=true                          # Sync Jira issues/comments to memory
LANGFUSE_ENABLED=true                           # LLM observability (adds ~16 GiB RAM)
MEMORY_CLASSIFIER_ENABLED=true                  # LLM-based memory type classification
PARZIVAL_ENABLED=true                           # Parzival project oversight agent
SECURITY_SCANNING_ENABLED=true                  # Security scanning for stored content


# =============================================================================
# SECTION 4: CONFIGURATION
# =============================================================================
# Grouped by subsystem. Defaults work out of the box.
# =============================================================================

# --- 4.1 LLM Providers & Models ---
OLLAMA_BASE_URL=http://host.docker.internal:11434  # Auto-detects cloud if OLLAMA_API_KEY is set
OLLAMA_MODEL=sam860/LFM2:2.6b                  # Ollama classification model
OPENROUTER_MODEL=google/gemma-2-9b-it:free      # OpenRouter classification model
ANTHROPIC_MODEL=claude-3-haiku-20240307         # Anthropic classification model
OPENAI_MODEL=gpt-4o-mini                        # OpenAI classification model

# --- 4.2 Memory Classifier ---
MEMORY_CLASSIFIER_PRIMARY_PROVIDER=ollama       # ollama | openrouter | claude | openai
MEMORY_CLASSIFIER_FALLBACK_PROVIDERS=openrouter # Comma-separated fallback chain
MEMORY_CLASSIFIER_CONFIDENCE_THRESHOLD=0.7      # Min confidence to accept LLM classification
MEMORY_CLASSIFIER_RULE_CONFIDENCE=0.85          # Confidence for rule-based classification
MEMORY_CLASSIFIER_MIN_CONTENT_LENGTH=20         # Skip classification for very short content
MEMORY_CLASSIFIER_TIMEOUT=30                    # LLM request timeout (seconds)
MEMORY_CLASSIFIER_MAX_TOKENS=500                # Max LLM response tokens
MEMORY_CLASSIFIER_MAX_INPUT_CHARS=4000          # Truncate input to LLM at this length

# --- 4.3 Context Injection ---
BOOTSTRAP_TOKEN_BUDGET=2500                     # Tier 1 startup injection budget (tokens)
INJECTION_CONFIDENCE_THRESHOLD=0.6              # Tier 2 min score to inject
INJECTION_BUDGET_FLOOR=500                      # Tier 2 minimum token budget
INJECTION_BUDGET_CEILING=1500                   # Tier 2 maximum token budget
# INJECTION_QUALITY_WEIGHT=0.5                  # Adaptive budget: retrieval quality weight
# INJECTION_DENSITY_WEIGHT=0.3                  # Adaptive budget: result density weight
# INJECTION_DRIFT_WEIGHT=0.2                    # Adaptive budget: topic drift weight
# INJECTION_HARD_FLOOR=0.45                     # Absolute minimum score to inject
# INJECTION_THRESHOLD_CONVENTIONS=0.65          # Per-collection score threshold
# INJECTION_THRESHOLD_CODE_PATTERNS=0.55        # Per-collection score threshold
# INJECTION_THRESHOLD_DISCUSSIONS=0.60          # Per-collection score threshold

# --- 4.4 Decay Scoring ---
DECAY_SEMANTIC_WEIGHT=0.7                       # Blend: 0.7 semantic + 0.3 temporal
DECAY_HALF_LIFE_CODE_PATTERNS=14                # Days until 50% decay (code patterns)
DECAY_HALF_LIFE_DISCUSSIONS=21                  # Days until 50% decay (discussions)
DECAY_HALF_LIFE_CONVENTIONS=60                  # Days until 50% decay (conventions)
DECAY_HALF_LIFE_JIRA_DATA=30                    # Days until 50% decay (Jira issues)
DECAY_HALF_LIFE_GITHUB=14                       # Days until 50% decay (GitHub data)
# DECAY_MIN_SCORE=0.1                           # Floor: never decay below this score
# DECAY_TYPE_OVERRIDES=                         # Per-type half-life overrides (key:days,key:days)

# --- 4.5 Freshness Detection ---
FRESHNESS_COMMIT_THRESHOLD_AGING=3              # Commits since stored -> "aging"
FRESHNESS_COMMIT_THRESHOLD_STALE=10             # Commits since stored -> "stale"
FRESHNESS_COMMIT_THRESHOLD_EXPIRED=25           # Commits since stored -> "expired"
# FRESHNESS_PENALTY_FRESH=1.0                   # Score multiplier for fresh memories
# FRESHNESS_PENALTY_AGING=0.9                   # Score multiplier for aging memories
# FRESHNESS_PENALTY_STALE=0.0                   # Score multiplier for stale memories
# FRESHNESS_PENALTY_EXPIRED=0.0                 # Score multiplier for expired memories
# FRESHNESS_PENALTY_UNVERIFIED=1.0              # Score multiplier for unverified memories
# FRESHNESS_PENALTY_UNKNOWN=0.8                 # Score multiplier for unknown freshness

# --- 4.6 Security Scanning ---
SECURITY_SCANNING_NER_ENABLED=true              # SpaCy NER entity detection (Layer 3)
SECURITY_BLOCK_ON_SECRETS=true                  # Block content with detected secrets (vs mask)
SECURITY_SCAN_GITHUB_MODE=relaxed               # GitHub content: relaxed | strict | off
SECURITY_SCAN_SESSION_MODE=relaxed              # Session content: relaxed | strict | off

# --- 4.7 GitHub Sync ---
GITHUB_BRANCH=main                              # Branch to sync from
GITHUB_SYNC_INTERVAL=1800                       # Sync interval (seconds, 1800 = 30 min)
GITHUB_SYNC_ON_START=true                       # Run full sync on container start
GITHUB_CODE_BLOB_MAX_SIZE=102400                # Max file size for code blob storage (bytes)
GITHUB_CODE_BLOB_EXCLUDE=node_modules,*.min.js,.git,__pycache__,*.pyc,build,dist,*.egg-info
# GITHUB_SYNC_TOTAL_TIMEOUT=1800                # Total timeout for code blob sync (seconds)
# GITHUB_SYNC_INSTALL_TIMEOUT=600               # Total timeout during install (seconds)
# GITHUB_SYNC_PER_FILE_TIMEOUT=60               # Per-file timeout (seconds)
# GITHUB_SYNC_CIRCUIT_BREAKER_THRESHOLD=5       # Consecutive failures before circuit break
# GITHUB_SYNC_CIRCUIT_BREAKER_RESET=60          # Seconds before circuit breaker resets

# --- 4.8 Jira Sync ---
JIRA_SYNC_DELAY_MS=100                          # Delay between Jira API calls (rate limiting)

# --- 4.9 Parzival Agent ---
PARZIVAL_USER_NAME=Developer                    # Your name (used in greetings and handoffs)
PARZIVAL_LANGUAGE=English                       # Communication language
PARZIVAL_DOC_LANGUAGE=English                   # Generated document language
PARZIVAL_OVERSIGHT_FOLDER=oversight             # Project-relative path to oversight directory
PARZIVAL_HANDOFF_RETENTION=10                   # Number of recent handoff files to keep

# --- 4.10 Langfuse Observability ---
LANGFUSE_BASE_URL=http://localhost:23100        # Langfuse web UI URL (for Python SDK)
LANGFUSE_RETENTION_DAYS=90                      # Trace retention (days)
LANGFUSE_FLUSH_INTERVAL=5                       # Trace flush worker interval (seconds)
LANGFUSE_TRACE_HOOKS=true                       # Trace hook executions
LANGFUSE_TRACE_SESSIONS=true                    # Trace session lifecycle

# --- 4.11 Embedding Models ---
MODEL_NAME_EN=jinaai/jina-embeddings-v2-base-en         # English text embedding model
MODEL_NAME_CODE=jinaai/jina-embeddings-v2-base-code     # Code embedding model
EMBEDDING_MODEL_DENSE_EN=jinaai/jina-embeddings-v2-base-en   # Dense vector model (English)
EMBEDDING_MODEL_DENSE_CODE=jinaai/jina-embeddings-v2-base-code # Dense vector model (code)
EMBEDDING_MEMORY_LIMIT=4G                       # Container memory limit (two models ~ 3GB)
# EMBEDDING_MAX_RETRIES=2                       # Retry on embedding timeout
# EMBEDDING_BACKOFF_BASE=1.0                    # Exponential backoff base (seconds)
# EMBEDDING_BACKOFF_CAP=15.0                    # Backoff ceiling (seconds)

# --- 4.12 Evaluator (LLM-as-Judge) ---
# Only needed if using provider=custom in evaluator_config.yaml
EVALUATOR_BASE_URL=                             # Custom LLM endpoint URL
EVALUATOR_API_KEY=                              # Custom LLM API key

# --- 4.13 Logging ---
AI_MEMORY_LOG_LEVEL=INFO                        # Python logging: DEBUG | INFO | WARNING | ERROR
QDRANT_LOG_LEVEL=INFO                           # Qdrant: TRACE | DEBUG | INFO | WARN | ERROR

# --- 4.14 Secrets Backend ---
AI_MEMORY_SECRETS_BACKEND=env-file              # sops-age | keyring | env-file


# =============================================================================
# SECTION 5: INTERNAL / ADVANCED — DO NOT CHANGE
# =============================================================================
# Ports, hardcoded defaults. Only change if you have port conflicts.
# =============================================================================

# --- Service Ports ---
QDRANT_PORT=26350                               # Qdrant HTTP API
QDRANT_GRPC_PORT=26351                          # Qdrant gRPC
EMBEDDING_PORT=28080                            # Embedding service
# QDRANT_TIMEOUT=30                             # Qdrant client timeout (seconds)

# --- Langfuse Ports ---
LANGFUSE_WEB_PORT=23100                         # Langfuse web UI
LANGFUSE_WORKER_PORT=23130                      # Langfuse async worker
LANGFUSE_POSTGRES_PORT=25432                    # Langfuse PostgreSQL
LANGFUSE_CLICKHOUSE_PORT=28123                  # Langfuse ClickHouse
LANGFUSE_REDIS_PORT=26379                       # Langfuse Redis
LANGFUSE_MINIO_PORT=29000                       # Langfuse MinIO (blob storage)

# --- Fixed Defaults ---
GRAFANA_ADMIN_USER=admin                        # Grafana admin username (do not change)
